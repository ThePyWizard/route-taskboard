# Copy this file to .env.local and fill in the values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API)

# Public - safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server only - NEVER expose this. Used for admin import + generating download links.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# The email(s) that get the Admin dashboard. Comma-separated.
ADMIN_EMAILS=jishnu@lascade.com

# ---- Cloudflare R2 (video file storage) ----
# Cloudflare Dashboard -> R2. Create a bucket, then create an R2 API token
# (Manage R2 API Tokens -> Create -> Object Read & Write) to get the keys.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=route-exports
